# MCP Gateway - Environment Configuration
# Copy this file to .env and customize for your deployment.

# =============================================================================
# QUICK START - 2 DECISIONS
# =============================================================================
# 1. Docling mode: CPU or GPU container (USE_DOCLING_GPU)
# 2. Vision API: External endpoint for VLM pipeline + picture descriptions
#
# Default: EasyOCR + Tableformer (standard pipeline, fast, works out of the box).
# Vision API is OPTIONAL - enables VLM document pipeline, picture descriptions,
# and web content tail-trimming.

# =============================================================================
# DECISION 1: DOCLING CONTAINER (based on your GPU)
# =============================================================================
# false = docling-serve-cpu (no GPU needed, works everywhere)
# true  = docling-serve-cu128 (NVIDIA GPU required, faster processing)

USE_DOCLING_GPU=false

# Docling service URL (both CPU and GPU use same port, only one runs at a time)
DOCLING_URL=http://localhost:5001
DOCLING_GPU_URL=http://localhost:5001

# =============================================================================
# DECISION 2: VISION API (optional, for VLM features)
# =============================================================================
# OpenAI-compatible endpoint for vision models (Qwen3-VL, GPT-4V, etc.)
# Used for: VLM document pipeline, picture descriptions, web content tail-trimming
#
# Leave EMPTY to skip VLM features (Docling still works with standard pipeline)
# Set to your vision API endpoint to enable all features
#
# Examples:
#   Local LM Studio:    http://localhost:1234/v1
#   Local llama.cpp:    http://localhost:8080/v1
#   Local vLLM:         http://localhost:8100/v1
#   Remote server:      http://192.168.1.100:1234/v1
#   Tailscale:          http://my-server.tailnet:1234/v1
#   Cloud (Together):   https://api.together.xyz/v1
#   Cloud (OpenAI):     https://api.openai.com/v1
#   Docker internal:    http://host.docker.internal:1234/v1

VISION_API_URL=

# API key for vision endpoint
#   Local (LM Studio/llama.cpp/vLLM): not-needed
#   Cloud (OpenAI/Together):          Your actual API key
VISION_API_KEY=not-needed

# Vision model name (must match what's loaded in your API)
VISION_MODEL=qwen3-vl-4b

# =============================================================================
# DOCLING PIPELINE CONFIGURATION
# =============================================================================
# Pipeline mode for document parsing:
#   "standard" - EasyOCR + Tableformer (works out of the box, no extra setup)
#                ~6s/page on GPU, ~70s for a 15-page PDF
#   "vlm"      - Vision-Language Model for OCR, tables, layout in one pass
#                With VISION_API_URL set: uses your external VLM (recommended!)
#                  -> Sends page images to your Vision API for conversion
#                  -> Speed depends on model (see presets below), concurrency=4 recommended
#                Without VISION_API_URL: falls back to local Granite-258M
#                  -> VERY SLOW (~29s/page), uses ~24GB VRAM, requires manual setup

DOCLING_PIPELINE=standard

# Enable picture descriptions (requires VISION_API_URL to be set)
DOCLING_DO_PICTURE_DESCRIPTION=true

# VLM max tokens per page (used for both external API and local Granite-258M)
DOCLING_VLM_MAX_TOKENS=4096

# VLM concurrent page requests (match your Vision API's max concurrent slots)
# LM Studio default: 4 slots. Higher = faster multi-page PDFs.
# With 4 slots: 15-page PDF in ~66s vs ~302s sequential
DOCLING_VLM_CONCURRENCY=1

# Local Granite-258M settings (only used when DOCLING_PIPELINE=vlm AND no VISION_API_URL)
DOCLING_VLM_REPO_ID=ibm-granite/granite-docling-258M

# Standard pipeline OCR engine (used when DOCLING_PIPELINE=standard)
DOCLING_OCR_ENGINE=easyocr

# =============================================================================
# VISION MODEL SAMPLING PARAMETERS
# =============================================================================
# These are passed to the vision API for VLM pipeline, picture descriptions,
# and web content tail-trimming. Only set the params your model uses.
#
# ---- PRESET: Qwen3-VL (2B/4B/8B) [RECOMMENDED] ----
# Tested: t=0.1 with pp=0.0 is optimal. pp=1.5 causes hallucinations.
# VLM_TEMPERATURE=0.1
# VLM_TOP_P=0.8
# VLM_TOP_K=20
# VLM_PRESENCE_PENALTY=0.0
# VLM_REPETITION_PENALTY=1.0
#
# ---- PRESET: LFM2.5-VL 1.6B [FASTEST] ----
# VLM_TEMPERATURE=0.1
# VLM_MIN_P=0.15
# VLM_REPETITION_PENALTY=1.05

# Active sampling config:
VLM_TEMPERATURE=0.1
VLM_TOP_P=0.8
VLM_TOP_K=20
#VLM_MIN_P=
# VLM_MAX_TOKENS removed — vLLM fills remaining context dynamically.
# Callers pass explicit max_tokens per-task (Docling=4096, tail-trim=100).
VLM_PRESENCE_PENALTY=0.0
VLM_REPETITION_PENALTY=1.0

# =============================================================================
# KNOWLEDGE BASE (Optional)
# =============================================================================
# OpenSearch URL for persistent knowledge base
# Leave empty to disable (SQLite cache still works)

OPENSEARCH_URL=http://localhost:9200

# =============================================================================
# PRELOAD FOLDER
# =============================================================================
# Drop PDFs, docs, etc. into this folder and they'll be indexed into the
# knowledge base automatically on startup. Idempotent — already-indexed files
# are skipped. Requires OpenSearch to be available.

PRELOAD_DIR=./preload
PRELOAD_ON_STARTUP=true

# =============================================================================
# WEB EXTRACTION PREFERENCES
# =============================================================================
# Method: auto, docling, local_chrome, docker_playwright, or markitdown
#   auto              - Docling pipeline (escalates HTML sources) + tail-trim (default)
#   docling           - Force Docling pipeline (direct HTTP -> Docker Playwright -> local Chrome)
#   local_chrome      - Force local Chrome -> Docling -> tail-trim (max bot resistance)
#   docker_playwright - Force Docker Playwright + MarkItDown (no LLM needed)
#   markitdown        - Force MarkItDown only (fast, no browser needed)

WEB_EXTRACTION_METHOD=auto
WEB_WAIT_FOR_JS=true

# Chrome extension token (only if using local Chrome via Playwright MCP)
PLAYWRIGHT_MCP_TOKEN=

# =============================================================================
# DOCKER PLAYWRIGHT AUTHENTICATION (Optional)
# =============================================================================
# For authenticated sessions in Docker (e.g., Google login)

PLAYWRIGHT_AUTH_STATE=./auth/playwright-state.json
# Headed mode with Xvfb (better bot resistance, only 8% slower than headless)
PLAYWRIGHT_DOCKER_HEADED=true

# =============================================================================
# SERVICE URLs (Usually don't need to change)
# =============================================================================

SEARXNG_URL=http://localhost:8080
CACHE_DIR=./cache

# =============================================================================
# PERFORMANCE TUNING
# =============================================================================

CHUNK_SIZE_TOKENS=4000
AUTO_FULL_THRESHOLD_TOKENS=4000

TIMEOUT_SEARCH=30
TIMEOUT_BROWSER=60
TIMEOUT_DOCLING=300
TIMEOUT_LLM=120
TIMEOUT_OPENSEARCH=10

# =============================================================================
# LOGGING
# =============================================================================
# Log level: DEBUG, INFO, WARNING, ERROR
# DEBUG: verbose output for troubleshooting
# INFO: normal operation (default)
# WARNING: only warnings and errors (quiet production)
LOG_LEVEL=INFO

# =============================================================================
# SECURITY
# =============================================================================
# Change this in production!
SEARXNG_SECRET=change-this-in-production

# =============================================================================
# CHAT UI (Optional)
# =============================================================================
# HuggingFace Chat UI v0.20+ — web chat interface.
# Access at http://localhost:3000 (included in standard, cpu, gpu profiles)
#
# Chat UI auto-discovers models from the OPENAI_BASE_URL /models endpoint.
# Point it at any OpenAI-compatible API:
#
# Examples:
#   OpenRouter (cloud):    https://openrouter.ai/api/v1  (needs API key)
#   LM Studio (local):    http://host.docker.internal:1234/v1
#   vLLM (local):         http://host.docker.internal:8100/v1
#   Bluefin (Tailscale):  http://bluefin:1234/v1

CHAT_UI_PORT=3000

# ORIGIN for SvelteKit CSRF validation.
# If accessing Chat UI from other machines (not just localhost), set this to the
# URL those machines use to reach it. Without this, POST requests (sending messages)
# return 403 from non-localhost origins.
#
# RECOMMENDED: Expose Chat UI via Tailscale HTTPS (solves CSRF for all machines):
#   tailscale serve --bg --https 8443 http://127.0.0.1:3000
#   Then set ORIGIN to the Tailscale HTTPS URL:
#   CHAT_UI_ORIGIN=https://your-machine.your-tailnet.ts.net:8443
#
# Other examples (HTTP, single-origin only):
#   Tailscale MagicDNS:  http://my-server:3000
#   Tailscale IP:        http://100.90.12.114:3000
#   LAN IP:              http://192.168.1.100:3000
CHAT_UI_ORIGIN=http://localhost:3000

CHAT_UI_BASE_URL=https://openrouter.ai/api/v1
CHAT_UI_API_KEY=  # OpenRouter key from https://openrouter.ai/keys
# HF_TOKEN=

# MCP tools for Chat UI (requires HTTPS — use Tailscale to expose the gateway)
# 1. Enable HTTPS in Tailscale admin: DNS → Enable HTTPS Certificates
# 2. Expose services via Tailscale:
#      tailscale serve --bg 8000                                    # Gateway → :443
#      tailscale serve --bg --https 8443 http://127.0.0.1:3000     # Chat UI → :8443
#      tailscale serve --bg --https 3001 http://127.0.0.1:3001     # Gitea   → :3001
# 3. Get your URL: tailscale serve status  (shows https://machine.tailnet.ts.net/)
# 4. Set MCP_SERVERS (the /mcp path is the Streamable HTTP transport endpoint):
# CHAT_UI_MCP_SERVERS=[{"name":"MCP Gateway","url":"https://your-machine.your-tailnet.ts.net/mcp"}]
CHAT_UI_MCP_SERVERS=

# MCP tool call timeout (milliseconds) — default 120s is too short for coding agent
# Goose tasks typically take 2-7 minutes; 600000 = 10 min
MCP_TOOL_TIMEOUT_MS=600000

# =============================================================================
# CODE EXECUTION SANDBOX (Optional)
# =============================================================================
# Enables run_code() MCP tool for executing Python/JS in isolated containers.
# Requires Docker socket access (/var/run/docker.sock mounted to gateway).
#
# SECURITY: Docker socket access allows the gateway container to manage other
# containers. Sandboxes run with no network, memory limits, and auto-removal.

# Sandbox container images (pre-pulled during deployment)
CODE_SANDBOX_PYTHON_IMAGE=python:3.11-slim
CODE_SANDBOX_NODE_IMAGE=node:20-slim

# Execution limits
CODE_SANDBOX_TIMEOUT=30
CODE_SANDBOX_MEMORY_LIMIT=256m
CODE_SANDBOX_CPU_LIMIT=1.0

# =============================================================================
# PLUGIN ENABLE FLAGS
# =============================================================================
# Control which tool groups are loaded. Disabled plugins don't register tools.
# Default: web, KB, processing enabled; code sandbox and coding agent disabled.

ENABLE_WEB_TOOLS=true           # search, fetch, fetch_section, cache
ENABLE_KB_TOOLS=true            # kb_search, kb_list, kb_remove, add_to_knowledge_base
ENABLE_PROCESSING_TOOLS=true    # process
ENABLE_CODE_EXECUTION=false     # run_code (requires Docker socket)
ENABLE_CODING_AGENT=false       # delegate_coding_agent, run_coding_agent, list_projects (requires Docker socket)

# =============================================================================
# CODING AGENT (Optional — 1 profile per CLI, model selected at dispatch)
# =============================================================================
# Autonomous coding agents in Docker. Each agent has MCP gateway tools
# (search, fetch, knowledge base, gitea). Model selected at dispatch time.
#
# Agent profiles (use with delegate_coding_agent(agent="...", model="...")):
#   goose           — Goose CLI (file tools + MCP gateway)
#   goose-reviewer  — Goose CLI review-only (MCP gateway tools only)
#   vibe            — Mistral Vibe CLI (file tools + MCP gateway)
#   qwen            — Qwen Code CLI (file tools + MCP gateway)
#   qwen-cloud      — Qwen Code CLI via qwen.ai cloud (free tier)
#   kimi            — Kimi Code CLI via kimi.com cloud + MCP gateway
#
# Model aliases (auto-swapped by llamaswap):
#   devstral    — Devstral Small 24B
#   qwen-coder  — Qwen3 Coder 30B A3B
#   qwen3-next  — Qwen3 Coder Next 80B MoE
#
# Docker images (build with `docker compose --profile build build`):
#   mcp-goose:latest  — Goose profiles
#   mcp-qwen:latest   — Qwen profiles
#   mcp-vibe:latest   — Vibe profile
#   mcp-kimi:latest   — Kimi profile

GOOSE_IMAGE=mcp-goose:latest
QWEN_IMAGE=mcp-qwen:latest
VIBE_IMAGE=mcp-vibe:latest
KIMI_IMAGE=mcp-kimi:latest

GOOSE_TIMEOUT=300
GOOSE_WORKSPACE=./workspace

# LLM endpoint (llamaswap auto-swaps models by name on single GPU)
LLM_HOST=http://host.docker.internal:8085
DEFAULT_MODEL=devstral

# Model GGUF filenames (used as aliases for llamaswap)
DEVSTRAL_MODEL=Devstral-Small-2-24B-Instruct-2512-IQ4_XS-4.04bpw.gguf
QWEN_CODER_MODEL=Qwen3-Coder-30B-A3B-Instruct-IQ4_XS-4.20bpw.gguf
QWEN3_NEXT_MODEL=Qwen3-Coder-Next-REAM-MXFP4_MOE.gguf
# LLAMASWAP_PORT=8085
# LLM_MODEL_DIR=/c/llm_models/byteshape

# MCP Gateway URL (agent uses this for search/fetch/KB tools)
GOOSE_MCP_GATEWAY_URL=http://gateway:8000

# Cloud agent API keys (needed for headless Docker — OAuth can't open browser)
# DASHSCOPE_API_KEY=            # Qwen cloud free tier (dashscope.aliyuncs.com)
# KIMI_API_KEY=                 # Kimi cloud (kimi.com account)

# =============================================================================
# GITEA GIT SERVER (Optional — persistent coding projects)
# =============================================================================
# Self-hosted Git server for named projects. When you pass project="name" to
# run_coding_agent(), the workspace is backed by a Gitea repo with full version
# history. Browse code and commits at http://localhost:3001
#
# Included in standard, cpu, gpu profiles (same as OpenSearch).
# Goose containers access Gitea via localhost:GITEA_PORT (network_mode=host).
#
# For remote access via Tailscale:
#   tailscale serve --bg --https 3001 http://127.0.0.1:3001
#   GITEA_PUBLIC_URL=https://your-machine.your-tailnet.ts.net:3001

GITEA_PORT=3001
GITEA_URL=http://gitea:3000
GITEA_PUBLIC_URL=
GITEA_ADMIN_USER=goose
GITEA_ADMIN_PASSWORD=goose-gitea-local
GITEA_ADMIN_EMAIL=goose@localhost

# =============================================================================
# DEPLOYMENT MODES SUMMARY
# =============================================================================
#
# MODE A: VLM via External API [BEST QUALITY] (GPU + Vision API)
# ---------------------------------------------------------------
# USE_DOCLING_GPU=true
# DOCLING_PIPELINE=vlm
# VISION_API_URL=http://my-server:1234/v1
# DOCLING_VLM_CONCURRENCY=4
# DOCLING_DO_PICTURE_DESCRIPTION=true
# -> Sends page images to your Vision API for full conversion
# -> Benchmarks (15-page PDF, concurrency=4):
#      Qwen3-VL 8B 4-bit: ~97s, most complete output, best tables + LaTeX math
#      Qwen3-VL 4B:       ~69s, best quality/speed ratio
#      Qwen3-VL 2B:       ~47s, good accuracy, LaTeX math
#      LFM2.5-VL 1.6B:    ~29s, fastest, minor number accuracy issues
# -> Zero local VRAM for VLM, also adds picture descriptions
#
# MODE B: Standard + Vision API [BEST BALANCE] (GPU + Vision API)
# ----------------------------------------------------------------
# USE_DOCLING_GPU=true
# DOCLING_PIPELINE=standard
# VISION_API_URL=http://my-server:1234/v1
# DOCLING_DO_PICTURE_DESCRIPTION=true
# -> EasyOCR + Tableformer (fast) + Vision API for picture descriptions only
# -> ~6s/page, good quality, low VRAM
#
# MODE C: Standard Only (CPU, no Vision)
# ----------------------------------------
# USE_DOCLING_GPU=false
# DOCLING_PIPELINE=standard
# VISION_API_URL=
# -> EasyOCR + Tableformer, works on any machine, no external dependencies
#
