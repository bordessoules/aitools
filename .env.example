# MCP Gateway Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# SERVICE URLs
# =============================================================================

# SearXNG search engine
SEARXNG_URL=http://localhost:8080

# LM Studio (OpenAI-compatible API)
LMSTUDIO_URL=http://localhost:1234/v1

# Docling services
DOCLING_URL=http://localhost:8001
DOCLING_GPU_URL=http://localhost:8002
USE_DOCLING_GPU=true

# OpenSearch (knowledge base)
OPENSEARCH_URL=http://localhost:9200

# =============================================================================
# BROWSER/PLAYWRIGHT (optional)
# =============================================================================

# Get your token from the Playwright MCP Chrome extension
PLAYWRIGHT_MCP_TOKEN=your_token_here

# =============================================================================
# CACHE
# =============================================================================

CACHE_DIR=./cache

# =============================================================================
# CHUNKING CONFIGURATION
# =============================================================================

CHUNK_SIZE_TOKENS=4000
AUTO_FULL_THRESHOLD_TOKENS=4000

# =============================================================================
# TIMEOUTS (seconds)
# =============================================================================

TIMEOUT_SEARCH=30
TIMEOUT_BROWSER=60
TIMEOUT_DOCLING=300
TIMEOUT_LLM=120

# =============================================================================
# LLM HYPERPARAMETERS - Vision Model (Qwen3-VL)
# =============================================================================

VLM_TEMPERATURE=0.7
VLM_TOP_P=0.8
VLM_TOP_K=20
VLM_MAX_TOKENS=16384
VLM_PRESENCE_PENALTY=1.5
VLM_REPETITION_PENALTY=1.0

# =============================================================================
# LLM HYPERPARAMETERS - Text Model
# =============================================================================

LLM_TEMPERATURE=1.0
LLM_TOP_P=1.0
LLM_TOP_K=40
LLM_MAX_TOKENS=32768
LLM_PRESENCE_PENALTY=2.0
LLM_REPETITION_PENALTY=1.0
